# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/lumiframe?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# First admin bootstrap (optional — used only by the seed script)
ADMIN_NAME=Studio Owner
ADMIN_EMAIL=admin@lumiframestudio.com
ADMIN_PASSWORD=ChangeMe123!

# SMTP Mail Settings (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=shrutifotography@gmail.com
SMTP_PASS=your_gmail_app_password
